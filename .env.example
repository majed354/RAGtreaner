telegram_bot_token=YOUR_TELEGRAM_BOT_TOKEN
admin_chat_id=123456789
bot_username=legal_consultation_bot
telegram_runtime_enabled=true

openrouter_api_key=YOUR_OPENROUTER_API_KEY
openrouter_model=moonshotai/kimi-k2
gemini_api_key=
gemini_model=gemini-2.5-flash
gemini_api_base_url=https://generativelanguage.googleapis.com/v1beta
ollama_base_url=http://host.docker.internal:11434
ollama_model=qwen2.5:7b-instruct
ollama_request_timeout_seconds=240
mlx_local_python_bin=./.venv/bin/python
mlx_local_model_path=./models/gemma-4-e2b-it-4bit
mlx_local_default_adapter_path=./adapters/gemma4-e2b-legal-modes-v3-resume-v1
mlx_local_routing_policy_path=./deployment/mode_adapter_routing_v2.json
mlx_local_budget_policy_path=./data/benchmarks/legal_modes_v1/generation_budget_policy.json
mlx_local_prompt_templates_dir=./data/benchmarks/legal_modes_v1/prompt_templates
mlx_local_runner_script_path=./scripts/mlx_local_generate.py
mlx_local_timeout_seconds=480

openai_api_key=YOUR_OPENAI_API_KEY
embedding_model=text-embedding-3-small
embedding_batch_size=64
generation_provider_default=openrouter
generation_temperature=0.2
generation_max_tokens=1500

knowledge_dir=./documents/knowledge
structured_chunks_path=./data/structured/chunks.jsonl
similarity_threshold=0.28
top_k_results=6
chunk_size=900
chunk_overlap=180
documents_sync_enabled=true
documents_sync_interval_seconds=3
official_sync_enabled=true
official_sync_interval_seconds=86400
official_sync_request_timeout_seconds=120

webhook_url=https://your-domain.com/webhook
server_host=0.0.0.0
server_port=8000
instance_label=codex-legal-rag
admin_panel_enabled=true
admin_panel_password=
runtime_settings_path=./data/runtime/runtime_settings.json

chroma_persist_dir=./data/chromadb
chroma_collection=saudi_legal_consultations
